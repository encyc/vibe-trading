# =============================================================================
# Vibe Trading Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Trading Settings
# -----------------------------------------------------------------------------
# Trading mode: paper (模拟交易) or live (实盘交易)
TRADING_MODE=paper

# Trading symbols (comma separated)
SYMBOLS=BTCUSDT,ETHUSDT

# Kline interval: 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M
INTERVAL=30m

# Risk Management
MAX_POSITION_SIZE=0.1          # Max position size per trade (USDT)
MAX_TOTAL_POSITION=0.3         # Max total position (USDT)
STOP_LOSS_PCT=0.02             # Stop loss percentage (2%)
TAKE_PROFIT_PCT=0.05           # Take profit percentage (5%)
LEVERAGE=5                     # Max leverage (1-125)

# Agent Settings
DEBATE_ROUNDS=2                # Number of debate rounds between researchers
ENABLE_MEMORY=true             # Enable BM25 memory system
MEMORY_TOP_K=3                 # Number of memories to retrieve

# -----------------------------------------------------------------------------
# Binance API Configuration
# -----------------------------------------------------------------------------

# Testnet (Paper Trading) - Get from https://testnet.binancefuture.com/
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Mainnet (Live Trading) - Get from https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_mainnet_api_key_here
BINANCE_API_SECRET=your_mainnet_api_secret_here

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# LLM 配置名称 (对应 backend/src/pi_ai/llm.yaml 中的配置)
# 可用配置: longcat, iflow, glm_4_7, big_pickle, gemini3_flash, gpt5_nao 等
# 查看 backend/src/pi_ai/llm.yaml 获取完整列表
LLM_MODEL=glm_4_7

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
XAI_API_KEY=your_xai_api_key_here

# CryptoCompare API (for news sentiment)
# Get your free API key from: https://www.cryptocompare.com/coins/guides/how-to-use-our-api/
# Note: CoinDesk acquired CryptoCompare's data business
# API documentation is now at: https://developers.coindesk.com/
#
# 功能可用性:
# - ✅ News API: 免费可用
# - ❌ Social Sentiment: 需要付费订阅 (Hobby Tier 或更高)
# - ✅ Fear & Greed Index: 免费 (无需 API key)
#
# 如果只需要新闻数据，免费 API key 即可。
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# LunarCrush API (for social media sentiment)
# Get your free API key from: https://lunarcrush.com/
# Provides social media metrics including mentions, sentiment, influencers
#
# 功能可用性:
# - ✅ Social Volume: 社交媒体提及量
# - ✅ Sentiment Score: 情绪分数
# - ✅ Influencers: 影响者数据
# - ✅ Galaxy Score: 综合评分
#
# 注意: API v4 可能需要付费订阅才能访问社交媒体数据端点。
# 免费tier key 可能无法访问 /api4/public/* 端点。
# 如果遇到 404 错误，考虑升级到付费订阅。
#
# Free tier: Limited access, may not support all endpoints
# Paid tier: Required for full social sentiment data access
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: Log to file
# LOG_FILE=./vibe_trading.log

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite database URL for storing klines and other data
DATABASE_URL=sqlite+aiosqlite:///./vibe_trading.db

# -----------------------------------------------------------------------------
# Advanced Settings
# -----------------------------------------------------------------------------
# Debug mode
DEBUG=false

# Session ID for tracking (optional)
# SESSION_ID=
